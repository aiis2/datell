{
  "name": "datell",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && tsc -p src/main/tsconfig.json && electron .\"",
    "build:rag": "node scripts/build-system-rag.js",
    "build": "node scripts/build-system-rag.js && tsc -p src/main/tsconfig.json && vite build && electron-builder",
    "build:win": "node scripts/build-icon-sprite.js && node scripts/build-system-rag.js && node -e \"try{require('fs').rmSync('release/datellData',{recursive:true,force:true})}catch(e){}\" && tsc -p src/main/tsconfig.json && vite build && electron-builder --win",
    "build:mac": "node scripts/build-system-rag.js && tsc -p src/main/tsconfig.json && vite build && electron-builder --mac",
    "build:linux": "node scripts/build-system-rag.js && tsc -p src/main/tsconfig.json && vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.datell.app",
    "productName": "Datell",
    "copyright": "Copyright © 2026",
    "asar": true,
    "extraResources": [
      {
        "from": "resources/system_knowledge",
        "to": "system_knowledge",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/vendor/duckdb",
        "to": "vendor/duckdb",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/*.ts",
      "!**/*.map",
      "!src/**",
      "!docs/**",
      "!scripts/**",
      "!*.config.*",
      "!tsconfig*",
      "!node_modules/kuzu/**",
      "!node_modules/@xenova/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico",
      "artifactName": "Datell-${version}-win-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Datell"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "Datell-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "title": "Datell",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icons/icon.png",
      "category": "Utility"
    }
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "description": "",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/pg": "^8.20.0",
    "@visactor/vtable": "^1.26.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.38",
    "kuzu": "^0.11.3",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.20.0",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.20.0",
    "postal-mime": "^2.7.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev20.0",
    "@tabler/icons": "^3.41.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
