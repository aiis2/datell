{
  "id": "apex-scatter-timeline",
  "type": "card",
  "name": "ApexCharts 时间轴散点图",
  "category": "chart",
  "tags": ["散点图", "时间轴", "ApexCharts", "事件时间线", "datetime scatter", "分类时序"],
  "description": "ApexCharts datetime 类型散点图，X 轴为时间，Y 轴为分类或数值维度，每个点表示某时间点发生的事件或数据。适合展示事件日志可视化、Bug 发生时间分布、用户行为时间散点等按时间分布的分类数据。使用 generate_chart_apex 工具生成。",
  "useCases": [
    "服务报警事件时间分布",
    "用户行为操作时间散点",
    "Bug/缺陷发现时间与严重程度",
    "订单异常时间点分布"
  ],
  "dataSchema": {
    "series": "时间轴散点系列：[{name, data:[{x:timestamp, y:numeric_or_category}]}]",
    "xaxis.type": "值必须为 'datetime'"
  },
  "htmlClassName": "card chart-card",
  "engineHint": "apexcharts",
  "interactionSupport": ["highlight"],
  "exampleHtml": "<div class=\"card chart-card\" data-card-id=\"chart_apex_scatter_tl\">\n  <h2 class=\"card-title\">服务告警事件时间分布</h2>\n  <div id=\"chart_apex_scatter_tl\"></div>\n  <script>\n  (function(){\n    function ts(d){return new Date(d).getTime();}\n    var options={\n      chart:{type:'scatter',height:260,toolbar:{show:false},animations:{enabled:!window.__REPORT_PRINT_MODE__},events:{dataPointSelection:function(e,ctx,c){window.__REPORT_EVENT_BUS__&&window.__REPORT_EVENT_BUS__.emit({type:'highlight',cardId:'chart_apex_scatter_tl',payload:{seriesIndex:c.seriesIndex,dataIndex:c.dataPointIndex}});}}},\n      series:[\n        {name:'严重',data:[[ts('2024-01-05'),3],[ts('2024-01-12'),3],[ts('2024-02-08'),3]]},\n        {name:'警告',data:[[ts('2024-01-08'),2],[ts('2024-01-20'),2],[ts('2024-02-15'),2],[ts('2024-03-01'),2]]},\n        {name:'信息',data:[[ts('2024-01-03'),1],[ts('2024-01-18'),1],[ts('2024-02-10'),1],[ts('2024-03-05'),1],[ts('2024-03-12'),1]]}\n      ],\n      xaxis:{type:'datetime',labels:{datetimeUTC:false}},\n      yaxis:{min:0,max:4,tickAmount:3,labels:{formatter:function(v){return ['','信息','警告','严重'][Math.round(v)]||'';}}},\n      colors:(window.__APEX_PALETTE__||['#ef4444','#f59e0b','#3b82f6']).slice(0,3),\n      markers:{size:8}\n    };\n    var apx=new ApexCharts(document.getElementById('chart_apex_scatter_tl'),options);\n    apx.render().then(function(){\n      window.__REPORT_EVENT_BUS__&&window.__REPORT_EVENT_BUS__.registerApex('chart_apex_scatter_tl',apx);\n    });\n  })();\n  <\/script>\n</div>"
}
