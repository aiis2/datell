{
  "id": "table-trend-inline",
  "type": "card",
  "name": "内嵌趋势线数据表格",
  "category": "table",
  "tags": ["趋势表格", "inline sparkline", "内嵌图表", "表格", "sparkline table", "数据趋势"],
  "description": "每行内嵌最近 N 期迷你趋势线（SVG 格式，无需 JS 图表库）的数据表格，让表格数据同时具备趋势可视化能力。适合在一张表中展示多个 KPI 指标的当期值、环比变化和近期趋势方向。",
  "useCases": [
    "多 KPI 指标汇总表（含各指标近7日趋势）",
    "各城市销售额表格带趋势箭头+迷你折线",
    "各渠道流量指标带趋势表",
    "产品表现综合数据表（转化/复购/销量+趋势）"
  ],
  "dataSchema": {
    "rows": "行数组：[{name, value, change, sparkValues:[6个历史值], status}]",
    "columns": "表头列名定义"
  },
  "htmlClassName": "card table-card table-sparkline",
  "engineHint": "pure-html",
  "interactionSupport": [],
  "exampleHtml": "<div class=\"card table-card\" data-card-id=\"table_trend\">\n  <h2 class=\"card-title\">核心指标趋势汇总</h2>\n  <div class=\"table-wrapper\">\n    <table class=\"data-table\">\n      <thead><tr><th>指标</th><th>当前值</th><th>环比</th><th>近6周趋势</th><th>状态</th></tr></thead>\n      <tbody>\n        <tr><td>DAU</td><td>128万</td><td class=\"text-green-500\">↑+8.3%</td><td><svg viewBox=\"0 0 60 20\" width=\"60\" height=\"20\"><polyline points=\"0,18 10,14 20,16 30,10 40,8 60,4\" fill=\"none\" stroke=\"#10b981\" stroke-width=\"2\"/></svg></td><td><span class=\"badge badge-green\">良好</span></td></tr>\n        <tr><td>转化率</td><td>3.82%</td><td class=\"text-red-500\">↓-0.3pp</td><td><svg viewBox=\"0 0 60 20\" width=\"60\" height=\"20\"><polyline points=\"0,4 10,6 20,8 30,10 40,14 60,16\" fill=\"none\" stroke=\"#ef4444\" stroke-width=\"2\"/></svg></td><td><span class=\"badge badge-yellow\">监控</span></td></tr>\n        <tr><td>GMV</td><td>¥12.8亿</td><td class=\"text-green-500\">↑+22%</td><td><svg viewBox=\"0 0 60 20\" width=\"60\" height=\"20\"><polyline points=\"0,16 10,14 20,12 30,10 40,7 60,4\" fill=\"none\" stroke=\"#10b981\" stroke-width=\"2\"/></svg></td><td><span class=\"badge badge-green\">良好</span></td></tr>\n      </tbody>\n    </table>\n  </div>\n</div>"
}
