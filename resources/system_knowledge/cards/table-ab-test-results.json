  "htmlClassName": "card table-card ab-table",
  "engineHint": "pure-html",
  "interactionSupport": [],
  "exampleHtml": "<div class=\"card table-card\" data-card-id=\"table_ab\">\n  <h2 class=\"card-title\">A/B 实验结果汇总</h2>\n  <div class=\"table-wrapper\">\n    <table class=\"data-table\" style=\"font-size:12px\">\n      <thead><tr><th>实验名称</th><th>指标</th><th>对照组</th><th>实验组</th><th>提升</th><th>p值</th><th>结论</th></tr></thead>\n      <tbody>\n        <tr><td>首页推荐算法v2</td><td>点击率</td><td>3.82%</td><td>4.21%</td><td class=\"text-green-500\">+10.2%</td><td>0.003</td><td><span class=\"badge badge-green\">✓ 上线</span></td></tr>\n        <tr><td>结算页简化流程</td><td>支付率</td><td>68.5%</td><td>69.8%</td><td class=\"text-green-500\">+1.9%</td><td>0.048</td><td><span class=\"badge badge-green\">✓ 上线</span></td></tr>\n        <tr><td>新人弹窗优惠</td><td>注册转化</td><td>12.3%</td><td>12.8%</td><td class=\"text-green-500\">+4.1%</td><td>0.182</td><td><span class=\"badge badge-gray\">待观察</span></td></tr>\n        <tr><td>搜索结果排序v3</td><td>成交转化</td><td>5.6%</td><td>5.4%</td><td class=\"text-red-500\">-3.6%</td><td>0.024</td><td><span class=\"badge badge-red\">✗ 拒绝</span></td></tr>\n      </tbody>\n    </table>\n  </div>\n</div>"
}
