  "exampleHtml": "<div class=\"card chart-card\" data-card-id=\"forecast_vs_actual\"><div class=\"card-title\">销售预测 vs 实际</div><div class=\"chart-container short\" id=\"chart_fva\"></div><script>(function(){var el=document.getElementById('chart_fva');if(!el)return;var c=echarts.init(el);var months=['1月','2月','3月','4月','5月','6月','7月','8月'];var actual=[520,558,531,590,null,null,null,null];var forecast=[530,560,540,580,600,620,610,640];var palette=window.__REPORT_PALETTE__||['#3b82f6','#10b981'];c.setOption({legend:{data:['实际','预测'],bottom:0},tooltip:{trigger:'axis'},xAxis:{type:'category',data:months},yAxis:{type:'value'},series:[{name:'实际',type:'line',data:actual,lineStyle:{color:palette[0],width:2},itemStyle:{color:palette[0]}},{name:'预测',type:'line',data:forecast,lineStyle:{color:palette[1],width:2,type:'dashed'},itemStyle:{color:palette[1]}}]});})();</script></div>",
