{
  "id": "volume-chart",
  "type": "card",
  "category": "B",
  "name": "成交量图",
  "description": "ECharts 成交量柱状图（上涨红/下跌绿），通常与K线图组合，展示价量关系",
  "tags": ["volume", "finance", "stock", "bar", "trading", "quantity", "echarts"],
  "cssClass": "chart-card",
  "renderLib": "echarts",
  "exampleHtml": "<div class=\"card chart-card\" data-card-id=\"volume_chart\"><div class=\"card-title\">成交量</div><div class=\"chart-container short\" id=\"chart_volume\"></div><script>(function(){var el=document.getElementById('chart_volume');if(!el)return;var c=echarts.init(el);var dates=['1/20','1/21','1/22','1/23','1/24'];var vol=[32000,28500,41200,25600,38900];var up=[true,false,true,false,true];c.setOption({tooltip:{trigger:'axis'},xAxis:{type:'category',data:dates},yAxis:{type:'value',axisLabel:{formatter:function(v){return (v/10000).toFixed(1)+'万';}}},series:[{type:'bar',data:vol.map(function(v,i){return{value:v,itemStyle:{color:up[i]?'#ef4444':'#10b981'}};}),barMaxWidth:40}]});})();</script></div>",
  "variants": ["股票成交量", "期货持仓量", "交易笔数"],
  "relatedCards": ["candlestick", "candlestick-ma"]
}
