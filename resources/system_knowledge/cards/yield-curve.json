{
  "id": "yield-curve",
  "type": "card",
  "name": "收益率曲线图",
  "category": "chart",
  "tags": ["收益率曲线", "利率", "债券", "金融", "期限结构", "yield curve"],
  "description": "展示不同期限债券的收益率曲线（Term Structure），可同时对比多个时间点的收益率曲线，用于分析利率期限结构变化、曲线平坦化/反转等特征。适用于固收投资分析报表。",
  "useCases": [
    "国债收益率曲线分析",
    "信用债期限利差对比",
    "利率曲线多日期对比",
    "央行政策前后曲线变化"
  ],
  "dataSchema": {
    "maturities": "期限数组，如 ['1M','3M','6M','1Y','2Y','5Y','10Y','30Y']",
    "series": "多条曲线，每条含 name（日期/场景）和 data（各期限收益率数值，单位%）"
  },
  "htmlClassName": "card chart-card",
  "engineHint": "echarts",
  "interactionSupport": ["highlight"],
  "exampleHtml": "<div class=\"card chart-card\" data-card-id=\"chart_yield\">\n  <h2 class=\"card-title\">国债收益率曲线</h2>\n  <div id=\"chart_yield\" class=\"chart-container\" style=\"height:300px\"></div>\n  <script>\n  (function(){\n    var mat=['1M','3M','6M','1Y','2Y','5Y','10Y','30Y'];\n    var chart=echarts.init(document.getElementById('chart_yield'));\n    chart.setOption({\n      legend:{},\n      xAxis:{type:'category',data:mat},\n      yAxis:{type:'value',axisLabel:{formatter:'{value}%'}},\n      series:[\n        {name:'2024-01',type:'line',data:[2.1,2.3,2.5,2.6,2.8,3.1,3.3,3.5],smooth:true},\n        {name:'2024-06',type:'line',data:[2.3,2.4,2.55,2.65,2.75,2.95,3.1,3.2],smooth:true,lineStyle:{type:'dashed'}}\n      ]\n    });\n    window.__REPORT_EVENT_BUS__ && window.__REPORT_EVENT_BUS__.register('chart_yield', chart);\n  })();\n  <\/script>\n</div>"
}
